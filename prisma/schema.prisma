datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid   String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  approved      Boolean   @default(false)
  name          String?
  createdAt     DateTime  @default(now())

  apps          App[]
  images        Image[]

  @@map("user")
}

model App {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apiKeys     ApiKey[]
  collections Collection[]
  images      Image[]

  @@index([tenantId])
}

enum ApiKeyScope {
  ALL
  READ
  WRITE
  DELETE
}

model ApiKey {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  key         String        @unique
  scopes      ApiKeyScope[] @default([ALL])

  createdAt   DateTime      @default(now())

  appId        String        @db.Uuid
  app          App           @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
}

model Collection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appId       String   @db.Uuid
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  images      Image[]

  @@index([appId])
}

model Image {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User-facing identifier (great for URLs/API)
  slug          String   @unique

  // Original upload metadata
  originalName  String
  mimeType      String
  format        String
  width         Int
  height        Int
  size          Int

  options       Json

  // Ownership (denormalized for fast auth)
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appId         String   @db.Uuid
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  collectionId  String   @db.Uuid
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variants      ImageVariant[]

  @@index([tenantId])
  @@index([appId])
  @@index([collectionId])
  @@index([createdAt])
}

model ImageVariant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imageId       String   @db.Uuid
  image         Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  slug          String
  format        String
  size          String

  width         Int
  height        Int
  fileSize      Int
  options       Json

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([imageId, size, format])
  @@index([imageId])
}