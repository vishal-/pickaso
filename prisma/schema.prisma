datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Tenant (Neon Auth User)
// Maps directly to Neon's auth table
// ==========================================
model Tenant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firebaseUid   String    @unique
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  createdAt     DateTime  @default(now())

  apps          App[]
  images        Image[]

  @@map("user")
}

model App {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apiKeys     ApiKey[]
  collections Collection[]
  images      Image[]

  @@index([tenantId])
}

enum ApiKeyScope {
  ALL
  READ
  WRITE
  DELETE
}

model ApiKey {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  key         String        @unique
  scopes      ApiKeyScope[] @default([ALL])

  createdAt   DateTime      @default(now())

  appId        String        @db.Uuid
  app          App           @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
}

model Collection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appId       String   @db.Uuid
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  images      Image[]

  @@index([appId])
}

model Image {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // User-facing identifier (great for URLs/API)
  slug          String   @unique

  // Original upload metadata
  originalName  String
  mimeType      String
  format        String
  width         Int
  height        Int
  size          Int

  // Upload/processing status
  status        ImageStatus @default(PROCESSING)

  // Flexible storage metadata
  // Example:
  // {
  //   "original": {...},
  //   "webp": {...},
  //   "thumbnail": {...},
  //   "medium": {...}
  // }
  variants      Json

  // Ownership (denormalized for fast auth)
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appId         String   @db.Uuid
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  collectionId  String   @db.Uuid
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([appId])
  @@index([collectionId])
  @@index([status])
  @@index([createdAt])
}

enum ImageStatus {
  PROCESSING
  READY
  FAILED
  DELETED
}